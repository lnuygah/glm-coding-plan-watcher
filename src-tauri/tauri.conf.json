{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GLM Plan Watcher",
  "version": "0.1.0",
  "identifier": "com.glm-plan-watcher.app",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "GLM Plan Watcher",
        "width": 1120,
        "height": 760,
        "minWidth": 900,
        "minHeight": 620,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "externalBin": ["../sidecar/bin/glm-plan-daemon"]
  }
}
